  "nodes": {
    "var_1bb10ce5e715": {
      "type": "variant",
      "label": "Isometric Technical Lab",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 0,
        "y": 0,
        "w": 1280,
        "h": 800
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --main-blue: #005BFF;\n    --text-navy: #06143D;\n    --accent-pink: #F72585;\n    --accent-purple: #7B2CFF;\n    --bg-light: #EEF7FF;\n  }\n\n  body {\n    font-family: 'Poppins', sans-serif;\n    background-color: var(--bg-light);\n    color: var(--text-navy);\n    margin: 0;\n    overflow-x: hidden;\n  }\n\n  /* Pattern: #dot-grid */\n  .dot-grid {\n    background-image: radial-gradient(var(--main-blue) 1px, transparent 1px);\n    background-size: 32px 32px;\n    opacity: 0.1;\n    position: absolute;\n    inset: 0;\n    pointer-events: none;\n  }\n\n  /* Pattern: #swiss-grid */\n  .swiss-grid-line-v {\n    position: absolute;\n    top: 0;\n    bottom: 0;\n    width: 1px;\n    background-color: var(--main-blue);\n    opacity: 0.15;\n    z-index: 1;\n  }\n\n  .swiss-grid-line-h {\n    position: absolute;\n    left: 0;\n    right: 0;\n    height: 1px;\n    background-color: var(--main-blue);\n    opacity: 0.15;\n    z-index: 1;\n  }\n\n  .bento-card {\n    background: white;\n    border: 1px solid rgba(0, 91, 255, 0.1);\n    box-shadow: 0 4px 20px rgba(6, 20, 61, 0.05);\n    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);\n  }\n\n  .bento-card:hover {\n    transform: translateY(-8px) scale(1.02);\n    border-color: var(--main-blue);\n  }\n\n  .registration-mark {\n    position: absolute;\n    width: 24px;\n    height: 24px;\n    opacity: 0.4;\n    z-index: 2;\n  }\n</style>\n\n<div class=\"relative min-h-screen flex flex-col\" data-kid=\"1\">\n  <div class=\"dot-grid\" data-kid=\"2\"></div>\n  \n  \n  <div class=\"swiss-grid-line-v left-[33%]\" data-kid=\"3\"></div>\n  <div class=\"swiss-grid-line-v left-[66%]\" data-kid=\"4\"></div>\n  <div class=\"swiss-grid-line-h top-24\" data-kid=\"5\"></div>\n  <div class=\"swiss-grid-line-h bottom-1/4\" data-kid=\"6\"></div>\n\n  \n  <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/cross-mark.svg\" class=\"registration-mark top-[84px] left-[calc(33%-12px)] grayscale invert brightness-0\" style=\"filter: opacity(0.2) drop-shadow(0 0 0 var(--main-blue));\" data-kid=\"7\">\n  <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/cross-mark.svg\" class=\"registration-mark top-[84px] left-[calc(66%-12px)] grayscale invert brightness-0\" style=\"filter: opacity(0.2) drop-shadow(0 0 0 var(--main-blue));\" data-kid=\"8\">\n\n  \n  <header class=\"relative z-10 w-full bg-white/50 backdrop-blur-md border-b-2 border-[var(--main-blue)]\" data-kid=\"9\">\n    <div class=\"max-w-7xl mx-auto px-8 h-24 flex items-center justify-between\" data-kid=\"10\">\n      \n      <a href=\"#\" class=\"flex items-center gap-3\" data-kid=\"11\">\n        <div class=\"w-10 h-10 bg-[var(--main-blue)] rounded-sm flex items-center justify-center\" data-kid=\"12\">\n          <i class=\"ti ti-atom-2 text-white text-2xl\" data-kid=\"13\"></i>\n        </div>\n        <span class=\"text-2xl font-bold tracking-tight uppercase\" data-kid=\"14\">Balloon <span class=\"text-[var(--main-blue)]\" data-kid=\"15\">Lab</span></span>\n      </a>\n\n      \n      <nav class=\"hidden md:flex items-center gap-10\" data-kid=\"16\">\n        <a href=\"#\" class=\"text-sm font-semibold hover:text-[var(--main-blue)] transition-colors uppercase tracking-wider\" data-kid=\"17\">Home</a>\n        <a href=\"#\" class=\"text-sm font-semibold hover:text-[var(--main-blue)] transition-colors uppercase tracking-wider\" data-kid=\"18\">Designs</a>\n        <a href=\"#\" class=\"text-sm font-semibold hover:text-[var(--main-blue)] transition-colors uppercase tracking-wider\" data-kid=\"19\">Occasions</a>\n        <a href=\"#\" class=\"text-sm font-semibold hover:text-[var(--main-blue)] transition-colors uppercase tracking-wider\" data-kid=\"20\">Gallery</a>\n        \n        <a href=\"#\" class=\"ml-4 bg-[var(--text-navy)] text-white px-8 py-3 text-sm font-bold uppercase tracking-widest hover:bg-[var(--main-blue)] transition-all transform hover:-translate-y-0.5 shadow-lg shadow-navy-900/20\" data-kid=\"21\">\n          Create Yours\n        </a>\n      </nav>\n    </div>\n  </header>\n\n  \n  <main class=\"relative z-10 flex-grow flex items-center\" data-kid=\"22\">\n    <div class=\"max-w-7xl mx-auto px-8 w-full py-20 grid lg:grid-cols-3 gap-16\" data-kid=\"23\">\n      \n      \n      <div class=\"lg:col-span-2 flex flex-col justify-center\" data-kid=\"24\">\n        <div class=\"mb-6 flex items-center gap-4\" data-kid=\"25\">\n          <span class=\"px-3 py-1 bg-[var(--main-blue)]/10 border border-[var(--main-blue)]/20 text-[var(--main-blue)] text-xs font-bold uppercase tracking-widest rounded-full\" data-kid=\"26\">\n            Made in the UAE 🇦🇪\n          </span>\n          <div class=\"h-[1px] w-20 bg-[var(--main-blue)]/20\" data-kid=\"27\"></div>\n        </div>\n\n        <h1 class=\"text-6xl lg:text-8xl font-bold leading-[0.9] tracking-tighter mb-8\" data-kid=\"28\">\n          PRINTED<br data-kid=\"29\">\n          <span class=\"text-[var(--main-blue)]\" data-kid=\"30\">MEMORIES</span><br data-kid=\"31\">\n          FLOATING.\n        </h1>\n\n        <p class=\"text-lg text-[var(--text-navy)]/70 max-w-xl mb-12 leading-relaxed\" data-kid=\"32\">\n          The Lab for custom photo balloons. High-definition prints on premium foil, delivered helium-filled to your doorstep in Dubai and beyond.\n        </p>\n\n        \n        <div class=\"grid grid-cols-1 md:grid-cols-2 gap-4 max-w-2xl\" data-kid=\"33\">\n          <div class=\"bento-card p-6 rounded-xl flex items-start gap-4\" id=\"card-1\" data-kid=\"34\">\n            <div class=\"p-3 bg-[var(--bg-light)] text-[var(--main-blue)] rounded-lg\" data-kid=\"35\">\n              <i class=\"ti ti-printer text-2xl\" data-kid=\"36\"></i>\n            </div>\n            <div data-kid=\"37\">\n              <h3 class=\"font-bold text-sm uppercase mb-1\" data-kid=\"38\">Hi-Res Printing</h3>\n              <p class=\"text-xs text-[var(--text-navy)]/60\" data-kid=\"39\">600 DPI photorealistic clarity on any surface.</p>\n            </div>\n          </div>\n\n          <div class=\"bento-card p-6 rounded-xl flex items-start gap-4\" id=\"card-2\" data-kid=\"40\">\n            <div class=\"p-3 bg-[var(--bg-light)] text-[var(--accent-purple)] rounded-lg\" data-kid=\"41\">\n              <i class=\"ti ti-wind text-2xl\" data-kid=\"42\"></i>\n            </div>\n            <div data-kid=\"43\">\n              <h3 class=\"font-bold text-sm uppercase mb-1\" data-kid=\"44\">Helium Filled</h3>\n              <p class=\"text-xs text-[var(--text-navy)]/60\" data-kid=\"45\">Long-lasting float time with industrial grade helium.</p>\n            </div>\n          </div>\n\n          <div class=\"bento-card p-6 rounded-xl flex items-start gap-4\" id=\"card-3\" data-kid=\"46\">\n            <div class=\"p-3 bg-[var(--bg-light)] text-[var(--accent-pink)] rounded-lg\" data-kid=\"47\">\n              <i class=\"ti ti-package text-2xl\" data-kid=\"48\"></i>\n            </div>\n            <div data-kid=\"49\">\n              <h3 class=\"font-bold text-sm uppercase mb-1\" data-kid=\"50\">Next-Day UAE</h3>\n              <p class=\"text-xs text-[var(--text-navy)]/60\" data-kid=\"51\">Fast laboratory-to-door delivery service.</p>\n            </div>\n          </div>\n\n          <div class=\"bento-card p-6 rounded-xl flex items-start gap-4\" id=\"card-4\" data-kid=\"52\">\n            <div class=\"p-3 bg-[var(--bg-light)] text-[var(--main-blue)] rounded-lg\" data-kid=\"53\">\n              <i class=\"ti ti-shield-check text-2xl\" data-kid=\"54\"></i>\n            </div>\n            <div data-kid=\"55\">\n              <h3 class=\"font-bold text-sm uppercase mb-1\" data-kid=\"56\">Durable Foil</h3>\n              <p class=\"text-xs text-[var(--text-navy)]/60\" data-kid=\"57\">Double-layered micro-foil prevents air leaks.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"relative flex items-center justify-center\" data-kid=\"58\">\n        \n        <div class=\"absolute inset-0 flex items-center justify-center opacity-10 pointer-events-none\" data-kid=\"59\">\n          <div class=\"w-full h-full border border-[var(--main-blue)] rounded-full rotate-45 scale-150\" data-kid=\"60\"></div>\n          <div class=\"absolute w-[80%] h-[80%] border border-[var(--main-blue)] rounded-full -rotate-12\" data-kid=\"61\"></div>\n        </div>\n\n        <div class=\"relative z-10 pedestal-container\" data-kid=\"62\">\n          <img src=\"https://images.unsplash.com/photo-1720293315632-37efe958d5ec?auto=format&w=800&q=80&fit=crop\" alt=\"3D Isometric Balloon Pedestal\" class=\"w-full h-auto drop-shadow-[0_40px_60px_rgba(0,91,255,0.2)] floating-balloon\" decoding=\"async\" loading=\"lazy\" data-kid=\"63\">\n          \n          \n          <div class=\"absolute -top-10 -right-10 w-24 h-24 bg-gradient-to-br from-[var(--accent-pink)] to-[var(--accent-purple)] rounded-full blur-3xl opacity-30 animate-pulse\" data-kid=\"64\"></div>\n          <div class=\"absolute -bottom-10 -left-10 w-32 h-32 bg-[var(--main-blue)] rounded-full blur-3xl opacity-10\" data-kid=\"65\"></div>\n        </div>\n      </div>\n\n    </div>\n  </main>\n\n  \n  <div class=\"swiss-grid-line-h bottom-12 opacity-5\" data-kid=\"66\"></div>\n</div>\n\n<script type=\"module\" data-kid=\"67\">\n  import { animate, spring } from \"https://cdn.jsdelivr.net/npm/motion@12/+esm\"\n\n  // Pattern: #motion-duration-bounce-spring for bento cards\n  animate(\n    \"#card-1, #card-2, #card-3, #card-4\",\n    { opacity: [0, 1], y: [20, 0], scale: [0.95, 1] },\n    { \n      delay: (i) => i * 0.1,\n      duration: 0.6,\n      easing: \"ease-out\"\n    }\n  );\n\n  // Pattern: #anime-ambient-float for the balloon/pedestal\n  animate(\n    \".floating-balloon\",\n    { y: [-15, 15] },\n    {\n      duration: 4,\n      repeat: Infinity,\n      direction: \"alternate\",\n      easing: \"ease-in-out\"\n    }\n  );\n\n  // Header entrance\n  animate(\n    \"header\",\n    { y: [-50, 0], opacity: [0, 1] },\n    { duration: 0.8, easing: \"ease-out\" }\n  );\n\n  // H1 reveal\n  animate(\n    \"h1\",\n    { opacity: [0, 1], x: [-30, 0] },\n    { duration: 1, easing: \"ease-out\" }\n  );\n</script>",
