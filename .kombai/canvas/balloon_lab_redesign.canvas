    "var_d856ea12698e": {
      "type": "variant",
      "label": "Floating Glossy 3D",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 1380,
        "y": 0,
        "w": 1280,
        "h": 800
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap');\n\n  .font-poppins {\n    font-family: 'Poppins', sans-serif;\n  }\n\n  /* Glassmorphism utility for floating cards */\n  .glass-card {\n    background: rgba(255, 255, 255, 0.45);\n    backdrop-filter: blur(16px);\n    border: 1px solid rgba(255, 255, 255, 0.6);\n    box-shadow: 0 8px 32px 0 rgba(31, 38, 135, 0.07);\n  }\n\n  .primary-btn {\n    background-color: #005BFF;\n    color: white;\n    box-shadow: 0 10px 25px rgba(0, 91, 255, 0.25);\n  }\n</style>\n\n<div class=\"font-poppins bg-[#EEF7FF] min-h-screen relative overflow-hidden\" data-kid=\"1\">\n  \n  \n  <header class=\"fixed top-8 left-1/2 -translate-x-1/2 w-full max-w-5xl z-50 px-4\" data-kid=\"2\">\n    <nav class=\"bg-white/40 backdrop-blur-xl border border-white/60 rounded-full px-8 py-3 flex items-center justify-between shadow-[0_20px_40px_rgba(0,91,255,0.08)]\" data-kid=\"3\">\n      <div class=\"flex items-center gap-3\" data-kid=\"4\">\n        <img src=\"https://images.unsplash.com/photo-1737108879273-12d4927a376a?auto=format&w=80&q=80&fit=crop\" alt=\"Balloon Lab Logo (Irene Demetri on Unsplash)\" class=\"w-10 h-10 object-contain\" decoding=\"async\" loading=\"lazy\" data-kid=\"5\">\n        <span class=\"text-xl font-bold text-[#06143D]\" data-kid=\"6\">Balloon Lab</span>\n      </div>\n      \n      <div class=\"hidden md:flex items-center gap-10\" data-kid=\"7\">\n        <a href=\"#\" class=\"text-[#06143D] hover:text-[#005BFF] font-medium transition-colors\" data-kid=\"8\">Home</a>\n        <a href=\"#\" class=\"text-[#06143D] hover:text-[#005BFF] font-medium transition-colors\" data-kid=\"9\">Designs</a>\n        <a href=\"#\" class=\"text-[#06143D] hover:text-[#005BFF] font-medium transition-colors\" data-kid=\"10\">Occasions</a>\n        <a href=\"#\" class=\"text-[#06143D] hover:text-[#005BFF] font-medium transition-colors\" data-kid=\"11\">How It Works</a>\n      </div>\n      \n      <button class=\"primary-btn font-semibold px-6 py-2.5 rounded-full hover:scale-105 transition-transform duration-300\" data-kid=\"12\">\n        Create Yours\n      </button>\n    </nav>\n  </header>\n\n  \n  <section class=\"relative pt-40 pb-20 px-8 max-w-7xl mx-auto flex items-center min-h-screen\" data-kid=\"13\">\n    \n    \n    <div class=\"w-full lg:w-[55%] z-10 hero-content\" data-kid=\"14\">\n      <div class=\"inline-flex items-center gap-2 bg-white/60 backdrop-blur-md border border-white/80 px-4 py-1.5 rounded-full mb-8\" data-kid=\"15\">\n        <span class=\"text-sm font-semibold text-[#005BFF] tracking-widest uppercase\" data-kid=\"16\">Made in the UAE</span>\n        <span class=\"text-lg\" data-kid=\"17\">🇦🇪</span>\n      </div>\n      \n      <h1 class=\"text-6xl md:text-7xl lg:text-8xl font-bold text-[#06143D] leading-[1.05] tracking-tight mb-8\" data-kid=\"18\">\n        Printed Memories,<br data-kid=\"19\">\n        Beautifully Floating\n      </h1>\n      \n      <p class=\"text-lg text-[#06143D]/70 max-w-xl mb-12 leading-relaxed\" data-kid=\"20\">\n        Custom photo balloons for birthdays, love moments, and unforgettable surprises. \n        Transform your favorite photos into floating works of art with premium print technology.\n      </p>\n      \n      <div class=\"flex flex-wrap gap-4\" data-kid=\"21\">\n        <button class=\"primary-btn font-semibold text-lg px-10 py-4 rounded-2xl hover:scale-[1.02] transition-transform duration-300\" data-kid=\"22\">\n          Start Your Balloon\n        </button>\n        <button class=\"bg-white/50 backdrop-blur-md border border-white font-semibold text-lg text-[#06143D] px-10 py-4 rounded-2xl hover:bg-white/80 transition-colors\" data-kid=\"23\">\n          View Designs\n        </button>\n      </div>\n\n      \n      <div class=\"mt-20 flex gap-12\" data-kid=\"24\">\n        <div class=\"flex items-center gap-4\" data-kid=\"25\">\n          <div class=\"w-12 h-12 rounded-xl bg-[#F72585]/10 flex items-center justify-center text-[#F72585]\" data-kid=\"26\">\n             <i class=\"ti ti-printer text-2xl\" data-kid=\"27\"></i>\n          </div>\n          <div data-kid=\"28\">\n            <p class=\"font-bold text-[#06143D]\" data-kid=\"29\">Premium Print</p>\n            <p class=\"text-sm text-[#06143D]/60\" data-kid=\"30\">Vibrant & Durable</p>\n          </div>\n        </div>\n        <div class=\"flex items-center gap-4\" data-kid=\"31\">\n          <div class=\"w-12 h-12 rounded-xl bg-[#7B2CFF]/10 flex items-center justify-center text-[#7B2CFF]\" data-kid=\"32\">\n             <i class=\"ti ti-package text-2xl\" data-kid=\"33\"></i>\n          </div>\n          <div data-kid=\"34\">\n            <p class=\"font-bold text-[#06143D]\" data-kid=\"35\">Fast Delivery</p>\n            <p class=\"text-sm text-[#06143D]/60\" data-kid=\"36\">Across the UAE</p>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"absolute right-0 top-0 bottom-0 w-[50%] pointer-events-none overflow-visible flex items-center justify-center\" data-kid=\"37\">\n      \n      <div class=\"relative w-full h-full flex items-center justify-center float-element-heavy\" data-kid=\"38\">\n        <img src=\"https://images.unsplash.com/photo-1633578155776-56b0c369bac8?auto=format&w=1280&q=80&fit=crop\" alt=\"3D Helium Balloons (Smit Patel on Unsplash)\" class=\"w-[120%] h-auto object-contain drop-shadow-[0_50px_100px_rgba(0,91,255,0.15)]\" decoding=\"async\" loading=\"lazy\" data-kid=\"39\">\n        \n        \n        <div class=\"absolute top-[20%] right-[10%] glass-card p-6 rounded-3xl w-60 rotate-[5deg] float-element-light\" data-kid=\"40\">\n          <div class=\"w-10 h-10 rounded-full bg-emerald-500/10 flex items-center justify-center mb-4\" data-kid=\"41\">\n            <i class=\"ti ti-star text-emerald-600\" data-kid=\"42\"></i>\n          </div>\n          <p class=\"font-bold text-[#06143D] mb-1\" data-kid=\"43\">5-Star Quality</p>\n          <p class=\"text-xs text-[#06143D]/60 leading-relaxed\" data-kid=\"44\">Trusted by over 50k happy customers across UAE.</p>\n        </div>\n\n        <div class=\"absolute bottom-[25%] left-[-10%] glass-card p-6 rounded-3xl w-56 rotate-[-3deg] float-element-med\" data-kid=\"45\">\n          <div class=\"flex -space-x-3 mb-4\" data-kid=\"46\">\n            <img src=\"https://i.pravatar.cc/100?u=1\" class=\"w-10 h-10 rounded-full border-2 border-white\" alt=\"User\" data-kid=\"47\">\n            <img src=\"https://i.pravatar.cc/100?u=2\" class=\"w-10 h-10 rounded-full border-2 border-white\" alt=\"User\" data-kid=\"48\">\n            <img src=\"https://i.pravatar.cc/100?u=3\" class=\"w-10 h-10 rounded-full border-2 border-white\" alt=\"User\" data-kid=\"49\">\n          </div>\n          <p class=\"font-bold text-[#06143D] text-sm leading-tight\" data-kid=\"50\">Join the celebration!</p>\n        </div>\n      </div>\n    </div>\n\n  </section>\n\n  \n  <div class=\"absolute -top-20 -left-20 w-96 h-96 bg-[#005BFF]/5 rounded-full blur-[100px] pointer-events-none\" data-kid=\"51\"></div>\n  <div class=\"absolute top-1/2 right-0 w-[500px] h-[500px] bg-[#F72585]/5 rounded-full blur-[120px] pointer-events-none\" data-kid=\"52\"></div>\n</div>\n\n\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"53\">\n<script src=\"https://cdn.jsdelivr.net/npm/gsap@3/dist/gsap.min.js\" data-kid=\"54\"></script>\n<script type=\"module\" data-kid=\"55\">\n  import { animate } from 'https://esm.sh/animejs@4';\n\n  // GSAP Entrance\n  gsap.from(\".hero-content > *\", {\n    opacity: 0,\n    y: 40,\n    stagger: 0.15,\n    duration: 1.2,\n    ease: \"power4.out\",\n    delay: 0.2\n  });\n\n  // Anime.js Floating Loops\n  // Heavy balloon cluster\n  animate(\".float-element-heavy\", {\n    translateY: [-15, 15],\n    rotate: [-1, 1],\n    duration: 5000,\n    direction: 'alternate',\n    loop: true,\n    easing: 'easeInOutQuad'\n  });\n\n  // Light cards (faster, more movement)\n  animate(\".float-element-light\", {\n    translateY: [-25, 25],\n    rotate: [5, 8],\n    duration: 4000,\n    direction: 'alternate',\n    loop: true,\n    easing: 'easeInOutSine'\n  });\n\n  // Medium cards\n  animate(\".float-element-med\", {\n    translateY: [-20, 20],\n    rotate: [-3, -6],\n    duration: 4500,\n    direction: 'alternate',\n    loop: true,\n    easing: 'easeInOutQuad'\n  });\n</script>",
