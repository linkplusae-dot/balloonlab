        "h": 800
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.css');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .font-poppins { font-family: 'Poppins', sans-serif; }\n\n  .neomorph-raised {\n    background: #EEF7FF;\n    box-shadow: 6px 6px 14px rgba(0, 0, 0, 0.07), -6px -6px 14px rgba(255, 255, 255, 0.85);\n  }\n\n  .frosted-panel {\n    background: rgba(255, 255, 255, 0.1);\n    backdrop-filter: blur(24px);\n    border: 1px solid rgba(255, 255, 255, 0.25);\n    box-shadow: 0 40px 100px rgba(6, 20, 61, 0.08);\n  }\n\n  .orbital-circle {\n    position: absolute;\n    top: 50%;\n    left: 50%;\n    transform: translate(-50%, -50%);\n    border: 1px solid rgba(6, 20, 61, 0.05);\n    border-radius: 50%;\n    pointer-events: none;\n  }\n\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n  .animate-marquee {\n    animation: marquee 30s linear infinite;\n  }\n\n  /* Locomotive Scroll Smoothness Fixes */\n  [data-scroll-container] {\n    perspective: 1px;\n  }\n</style>\n\n<div class=\"font-poppins bg-[#EEF7FF] text-[#06143D] selection:bg-[#005BFF] selection:text-white\" data-scroll-container data-kid=\"1\">\n  \n  \n  <header class=\"absolute top-0 left-0 w-full z-50 flex items-center justify-between px-12 py-8\" data-kid=\"2\">\n    <div class=\"flex items-center gap-3\" data-kid=\"3\">\n      <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-[#005BFF] to-[#7B2CFF] flex items-center justify-center shadow-lg shadow-blue-500/20\" data-kid=\"4\">\n        <i class=\"ti ti-balloon text-white text-xl\" data-kid=\"5\"></i>\n      </div>\n      <span class=\"text-xl font-bold tracking-tight\" data-kid=\"6\">Balloon <span class=\"text-[#005BFF]\" data-kid=\"7\">Lab</span></span>\n    </div>\n\n    <nav class=\"hidden md:flex items-center gap-10 text-sm font-medium\" data-kid=\"8\">\n      <a href=\"#\" class=\"hover:text-[#005BFF] transition-colors\" data-kid=\"9\">Home</a>\n      <a href=\"#\" class=\"hover:text-[#005BFF] transition-colors\" data-kid=\"10\">Designs</a>\n      <a href=\"#\" class=\"hover:text-[#005BFF] transition-colors\" data-kid=\"11\">Occasions</a>\n      <a href=\"#\" class=\"hover:text-[#005BFF] transition-colors\" data-kid=\"12\">How It Works</a>\n    </nav>\n\n    <a href=\"#\" class=\"neomorph-raised px-8 py-3 rounded-2xl text-sm font-semibold transition-all hover:scale-105 active:scale-95\" data-kid=\"13\">\n      Start Order\n    </a>\n  </header>\n\n  \n  <section class=\"relative min-h-screen flex items-center justify-center overflow-hidden pt-20\" data-kid=\"14\">\n    \n    \n    <div class=\"orbital-circle w-[400px] h-[400px]\" data-kid=\"15\"></div>\n    <div class=\"orbital-circle w-[700px] h-[700px]\" data-kid=\"16\"></div>\n    <div class=\"orbital-circle w-[1000px] h-[1000px]\" data-kid=\"17\"></div>\n    <div class=\"orbital-circle w-[1300px] h-[1300px]\" data-kid=\"18\"></div>\n\n    \n    \n    <div class=\"absolute top-[15%] left-[10%] w-64 h-64 z-10\" data-scroll data-scroll-speed=\"2.5\" data-kid=\"19\">\n      <img src=\"https://images.unsplash.com/photo-1429087969512-1e85aab2683d?auto=format&w=600&q=80&fit=crop\" alt=\"3D Metallic Pink Balloon by Florian Klauer\" class=\"w-full h-full object-contain drop-shadow-[0_20px_50px_rgba(247,37,133,0.3)] balloon-float-1\" decoding=\"async\" loading=\"lazy\" data-kid=\"20\">\n    </div>\n\n    \n    <div class=\"absolute bottom-[20%] right-[12%] w-72 h-72 z-30\" data-scroll data-scroll-speed=\"-1.5\" data-kid=\"21\">\n      <img src=\"https://images.pexels.com/photos/2534579/pexels-photo-2534579.jpeg?auto=compress&cs=tinysrgb&w=600&q=80\" alt=\"Glossy Purple Balloon by Deeana Arts\" class=\"w-full h-full object-contain drop-shadow-[0_20px_50px_rgba(123,44,255,0.3)] balloon-float-2\" decoding=\"async\" loading=\"lazy\" data-kid=\"22\">\n    </div>\n\n    \n    <div class=\"absolute top-[25%] right-[8%] w-[400px] h-[400px] z-0 opacity-40 blur-sm\" data-scroll data-scroll-speed=\"0.8\" data-kid=\"23\">\n      <img src=\"https://images.unsplash.com/photo-1554719956-5c151ab80680?auto=format&w=800&q=80&fit=crop\" alt=\"Blue Balloon Cluster by Siora Photography\" class=\"w-full h-full object-contain balloon-float-3\" decoding=\"async\" loading=\"lazy\" data-kid=\"24\">\n    </div>\n\n    \n    <div class=\"relative z-20 mx-auto max-w-3xl text-center px-6\" data-kid=\"25\">\n      <div id=\"central-card\" class=\"frosted-panel rounded-[3rem] p-12 md:p-20 flex flex-col items-center\" data-kid=\"26\">\n        <span class=\"inline-block px-4 py-1.5 rounded-full bg-[#005BFF]/10 text-[#005BFF] text-xs font-bold tracking-widest uppercase mb-8\" data-kid=\"27\">\n          Premium Balloon Lab\n        </span>\n        \n        <h1 class=\"text-6xl md:text-8xl font-bold tracking-tight leading-[0.9] mb-8\" data-kid=\"28\">\n          Elevate Every <br data-kid=\"29\">\n          <span class=\"text-[#005BFF]\" data-kid=\"30\">Occasion</span>\n        </h1>\n        \n        <p class=\"text-lg md:text-xl text-[#06143D]/70 max-w-xl mx-auto mb-12 leading-relaxed\" data-kid=\"31\">\n          Transform your favorite moments into floating memories with our custom 3D printed photo balloons.\n        </p>\n\n        <div class=\"flex flex-col sm:flex-row gap-5\" data-kid=\"32\">\n          <button class=\"px-10 py-5 rounded-2xl bg-[#005BFF] text-white font-semibold text-lg shadow-xl shadow-blue-500/25 hover:bg-[#0047cc] transition-all transform hover:-translate-y-1\" data-kid=\"33\">\n            Create Your Balloon\n          </button>\n          <button class=\"px-10 py-5 rounded-2xl border-2 border-[#06143D]/10 font-semibold text-lg hover:bg-white/50 transition-all\" data-kid=\"34\">\n            View Gallery\n          </button>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"absolute bottom-12 left-0 w-full z-40\" data-kid=\"35\">\n      <div class=\"max-w-7xl mx-auto px-12\" data-kid=\"36\">\n        <p class=\"text-center text-xs font-bold uppercase tracking-[0.3em] text-[#06143D]/40 mb-8\" data-kid=\"37\">Trusted by UAE's Finest Celebrators</p>\n        <div class=\"relative overflow-hidden\" data-kid=\"38\">\n          <div class=\"flex items-center gap-16 animate-marquee whitespace-nowrap\" data-kid=\"39\">\n            \n            <span class=\"text-3xl font-bold text-[#06143D]/10 px-8\" data-kid=\"40\">EMAAR</span>\n            <span class=\"text-3xl font-bold text-[#06143D]/10 px-8\" data-kid=\"41\">DUBAI MALL</span>\n            <span class=\"text-3xl font-bold text-[#06143D]/10 px-8\" data-kid=\"42\">ATLANTIS</span>\n            <span class=\"text-3xl font-bold text-[#06143D]/10 px-8\" data-kid=\"43\">BURJ KHALIFA</span>\n            <span class=\"text-3xl font-bold text-[#06143D]/10 px-8\" data-kid=\"44\">JUMEIRAH</span>\n            <span class=\"text-3xl font-bold text-[#06143D]/10 px-8\" data-kid=\"45\">EMAAR</span>\n            <span class=\"text-3xl font-bold text-[#06143D]/10 px-8\" data-kid=\"46\">DUBAI MALL</span>\n            <span class=\"text-3xl font-bold text-[#06143D]/10 px-8\" data-kid=\"47\">ATLANTIS</span>\n            <span class=\"text-3xl font-bold text-[#06143D]/10 px-8\" data-kid=\"48\">BURJ KHALIFA</span>\n            <span class=\"text-3xl font-bold text-[#06143D]/10 px-8\" data-kid=\"49\">JUMEIRAH</span>\n          </div>\n          \n          <div class=\"absolute inset-y-0 left-0 w-32 bg-gradient-to-r from-[#EEF7FF] to-transparent pointer-events-none\" data-kid=\"50\"></div>\n          <div class=\"absolute inset-y-0 right-0 w-32 bg-gradient-to-l from-[#EEF7FF] to-transparent pointer-events-none\" data-kid=\"51\"></div>\n        </div>\n      </div>\n    </div>\n\n  </section>\n</div>\n\n<script src=\"https://cdn.jsdelivr.net/npm/locomotive-scroll@5/bundled/locomotive-scroll.min.js\" data-kid=\"52\"></script>\n<script type=\"module\" data-kid=\"53\">\n  import { animate } from 'https://esm.sh/animejs@4';\n\n  // Initialize Locomotive Scroll\n  const scroll = new LocomotiveScroll({\n    el: document.querySelector('[data-scroll-container]'),\n    smooth: true,\n    multiplier: 1.2\n  });\n\n  // Ambient Floating Animations\n  animate('.balloon-float-1', {\n    translateY: [-20, 20],\n    rotate: [-5, 5],\n    duration: 5000,\n    direction: 'alternate',\n    loop: true,\n    easing: 'easeInOutQuad'\n  });\n\n  animate('.balloon-float-2', {\n    translateY: [15, -15],\n    rotate: [8, -8],\n    duration: 6000,\n    direction: 'alternate',\n    loop: true,\n    easing: 'easeInOutSine'\n  });\n\n  animate('.balloon-float-3', {\n    translateY: [-10, 10],\n    scale: [1, 1.05],\n    duration: 8000,\n    direction: 'alternate',\n    loop: true,\n    easing: 'easeInOutQuad'\n  });\n\n  // Breathing Pulse for Central Card\n  animate('#central-card', {\n    scale: [1, 1.01],\n    duration: 4000,\n    direction: 'alternate',\n    loop: true,\n    easing: 'easeInOutQuad'\n  });\n</script>",
